rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function usernameEmail(username) {
      return username + "@azobss.local";
    }

    function isSelf(username) {
      return signedIn()
        && request.auth.token.email == usernameEmail(username);
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "zedan91@azobss.local";
    }

    function selfProfileUpdateOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "name",
        "phone",
        "contactEmail",
        "online",
        "lastSeenMs",
        "lastLoginMs",
        "lastLoginAt",
        "loginCount",
        "updatedAt"
      ]);
    }

    match /users/{username} {
      allow read: if isAdmin() || isSelf(username);

      allow create: if isSelf(username)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameKey == username
        && request.resource.data.email == usernameEmail(username);

      allow update: if isAdmin()
        || (isSelf(username)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.usernameKey == username
          && request.resource.data.email == resource.data.email
          && request.resource.data.paAccess == resource.data.paAccess
          && request.resource.data.deleted == resource.data.deleted
          && selfProfileUpdateOnly());

      allow delete: if false;
    }

    match /purchaseSummaries/{username} {
      allow read: if isAdmin() || isSelf(username);
      allow create, update: if isAdmin() || isSelf(username);
      allow delete: if false;
    }

    match /purchaseLogs/{purchaseId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;

      allow update, delete: if false;
    }

    match /settings/signupGate {
      allow read: if true;
      allow create, update: if isAdmin()
        || (signedIn()
          && resource.data.open == true
          && resource.data.claimedBy == null
          && request.resource.data.claimedBy != null
          && request.resource.data.open == false);
      allow delete: if false;
    }

    match /sitePresence/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if false;
    }

    match /siteStats/traffic {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
